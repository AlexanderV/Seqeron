<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <!-- Azimuth / Rule Set 2 oracle vectors generated by scripts/azimuth/extract_azimuth_model.py
         (this project's verified Python reference). Embedded so the suite is self-contained. -->
    <EmbeddedResource Include="TestData\Azimuth\nopos_oracle.csv" />
    <EmbeddedResource Include="TestData\Azimuth\full_oracle.csv" />
    <!-- ONCO-MHC-001: one MHCflurry models_class1_pan affinity network (smallest member, feedforward
         [512,512]), exported from the Apache-2.0 weights_*.npz dense kernels/biases. Embedded so the
         forward-pass parity test runs without an external mhcflurry install. -->
    <EmbeddedResource Include="TestData\Mhcflurry\mhcflurry_single_net.bin" />
    <!-- MHC-NN-001: a tiny synthetic "with-skip-connections" network pack (3 hidden + output, deterministic
         weights) used to exercise the densenet skip-connection forward-pass wiring that the feedforward
         single_net pack does not cover. Golden raw output computed by an independent NumPy reference. -->
    <EmbeddedResource Include="TestData\Mhcflurry\mhcflurry_skip_net.bin" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit.Analyzers" />
    <PackageReference Include="NUnit3TestAdapter" />
    <!-- Tier 1: Fluent assertions with better failure messages -->
    <PackageReference Include="FluentAssertions" />
    <!-- Tier 2: Property-based testing for mathematical invariants -->
    <PackageReference Include="FsCheck" />
    <PackageReference Include="FsCheck.NUnit" />
    <!-- Tier 2: Snapshot/approval testing for complex outputs -->
    <PackageReference Include="Verify.NUnit" />
    <!-- Tier 3: Architecture guard tests -->
    <PackageReference Include="TngTech.ArchUnitNET.NUnit" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="NUnit.Framework" />
    <Using Include="Seqeron.Genomics.Core" />
    <Using Include="Seqeron.Genomics.Infrastructure" />
    <Using Include="Seqeron.Genomics.IO" />
    <Using Include="Seqeron.Genomics.Alignment" />
    <Using Include="Seqeron.Genomics.Analysis" />
    <Using Include="Seqeron.Genomics.Annotation" />
    <Using Include="Seqeron.Genomics.Phylogenetics" />
    <Using Include="Seqeron.Genomics.Population" />
    <Using Include="Seqeron.Genomics.Metagenomics" />
    <Using Include="Seqeron.Genomics.MolTools" />
    <Using Include="Seqeron.Genomics.Chromosome" />
    <Using Include="Seqeron.Genomics.Reports" />
    <Using Include="Seqeron.Genomics.Oncology" />
    <Using Include="FluentAssertions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics\Seqeron.Genomics.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Infrastructure\Seqeron.Genomics.Infrastructure.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Core\Seqeron.Genomics.Core.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.IO\Seqeron.Genomics.IO.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Alignment\Seqeron.Genomics.Alignment.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Analysis\Seqeron.Genomics.Analysis.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Annotation\Seqeron.Genomics.Annotation.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Phylogenetics\Seqeron.Genomics.Phylogenetics.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Population\Seqeron.Genomics.Population.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Metagenomics\Seqeron.Genomics.Metagenomics.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.MolTools\Seqeron.Genomics.MolTools.csproj" />
    <ProjectReference Include="..\..\..\src\Seqeron\Algorithms\Seqeron.Genomics.Chromosome\Seqeron.Genomics.Chromosome.csproj" />
