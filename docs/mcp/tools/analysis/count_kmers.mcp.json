{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "count_kmers",
  "serverName": "Analysis",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "KmerAnalyzer.CountKmers",
  "docRef": "Seqeron.Genomics.Analysis/KmerAnalyzer.cs#L20",
  "description": "Counts every overlapping k-mer occurrence in a sequence. Returns k-mer -> count; counts sum to L - k + 1.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequence": { "type": "string", "description": "Sequence to analyze", "minLength": 1 },
      "k": { "type": "integer", "description": "k-mer length", "minimum": 1 }
    },
    "required": ["sequence", "k"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "counts": {
        "type": "object",
        "description": "Map of k-mer -> occurrence count",
        "additionalProperties": { "type": "integer" }
      }
    },
    "required": ["counts"]
  },
  "errors": [
    { "code": 1001, "message": "Sequence cannot be null or empty" },
    { "code": 1003, "message": "k must be positive" }
  ],
  "examples": [
    {
      "name": "Homopolymer",
      "input": { "sequence": "AAAA", "k": 2 },
      "output": { "counts": { "AA": 3 } }
    },
    {
      "name": "Mixed 3-mers",
      "input": { "sequence": "ATGATG", "k": 3 },
      "output": { "counts": { "ATG": 2, "TGA": 1, "GAT": 1 } }
    }
  ]
}
