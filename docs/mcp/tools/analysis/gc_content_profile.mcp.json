{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "gc_content_profile",
  "serverName": "Analysis",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "SequenceStatistics.CalculateGcContentProfile",
  "docRef": "Seqeron.Genomics.Analysis/SequenceStatistics.cs#L905",
  "description": "GC content (percentage, 0-100) in sliding windows along a nucleotide sequence. GC = (G + C) / (A + T + U + G + C) x 100; ambiguous symbols are excluded.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequence": { "type": "string", "description": "Nucleotide sequence", "minLength": 1 },
      "windowSize": { "type": "integer", "description": "Window size (default 100)", "minimum": 1, "default": 100 },
      "stepSize": { "type": "integer", "description": "Step size (default 1)", "minimum": 1, "default": 1 }
    },
    "required": ["sequence"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "values": {
        "type": "array",
        "description": "GC percentage per window (0-100)",
        "items": { "type": "number" }
      }
    },
    "required": ["values"]
  },
  "errors": [
    { "code": 1001, "message": "Sequence cannot be null or empty" },
    { "code": 1002, "message": "Window size must be at least 1" },
    { "code": 1002, "message": "Step size must be at least 1" }
  ],
  "examples": [
    {
      "name": "GC-rich windows GGCC (window 2, step 1)",
      "input": { "sequence": "GGCC", "windowSize": 2, "stepSize": 1 },
      "output": { "values": [100.0, 100.0, 100.0] }
    },
    {
      "name": "AT-only windows, non-overlapping (window 2, step 2)",
      "input": { "sequence": "ATAT", "windowSize": 2, "stepSize": 2 },
      "output": { "values": [0.0, 0.0] }
    }
  ]
}
