{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "find_reciprocal_best_hits",
  "serverName": "Analysis",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "ComparativeGenomics.FindReciprocalBestHits",
  "docRef": "Seqeron.Genomics.Analysis/ComparativeGenomics.cs#L466",
  "description": "Reciprocal best hits (RBH) between two genomes for stricter ortholog identification: a pair is returned only when each gene is the other's best hit. Requires gene sequences.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "genome1Genes": { "type": "array", "description": "Genes of genome 1 (with sequence)" },
      "genome2Genes": { "type": "array", "description": "Genes of genome 2 (with sequence)" },
      "minIdentity": { "type": "number", "description": "Minimum identity (default 0.3)", "default": 0.3 }
    },
    "required": ["genome1Genes", "genome2Genes"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "gene1Id": { "type": "string" },
            "gene2Id": { "type": "string" },
            "identity": { "type": "number" },
            "coverage": { "type": "number" },
            "alignmentLength": { "type": "integer" }
          },
          "required": ["gene1Id", "gene2Id", "identity", "coverage", "alignmentLength"]
        }
      }
    },
    "required": ["items"]
  },
  "errors": [],
  "examples": [
    {
      "name": "Two reciprocal best hits",
      "input": { "genome1Genes": [ { "id": "a1", "genomeId": "G1", "start": 0, "end": 14, "strand": "+", "sequence": "ACGTACGTACGTAC" }, { "id": "a2", "genomeId": "G1", "start": 0, "end": 16, "strand": "+", "sequence": "TTTTGGGGCCCCAAAA" } ], "genome2Genes": [ { "id": "b1", "genomeId": "G2", "start": 0, "end": 14, "strand": "+", "sequence": "ACGTACGTACGTAC" }, { "id": "b2", "genomeId": "G2", "start": 0, "end": 16, "strand": "+", "sequence": "TTTTGGGGCCCCAAAA" } ] },
      "output": { "items": [ { "gene1Id": "a1", "gene2Id": "b1" }, { "gene1Id": "a2", "gene2Id": "b2" } ] }
    }
  ]
}
