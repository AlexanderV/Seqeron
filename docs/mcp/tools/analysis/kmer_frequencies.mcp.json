{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "kmer_frequencies",
  "serverName": "Analysis",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "KmerAnalyzer.GetKmerFrequencies",
  "docRef": "Seqeron.Genomics.Analysis/KmerAnalyzer.cs#L177",
  "description": "Normalized k-mer frequencies: each distinct k-mer's count divided by the total number of overlapping k-mers. Values are in [0,1] and sum to 1.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequence": { "type": "string", "description": "Sequence to analyze", "minLength": 1 },
      "k": { "type": "integer", "description": "k-mer length", "minimum": 1 }
    },
    "required": ["sequence", "k"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "frequencies": {
        "type": "object",
        "description": "Map from k-mer to its normalized frequency in [0,1]",
        "additionalProperties": { "type": "number" }
      }
    },
    "required": ["frequencies"]
  },
  "errors": [
    { "code": 1001, "message": "Sequence cannot be null or empty" },
    { "code": 1003, "message": "k must be positive" }
  ],
  "examples": [
    {
      "name": "Monomer frequencies ATGC k=1",
      "input": { "sequence": "ATGC", "k": 1 },
      "output": { "frequencies": { "A": 0.25, "T": 0.25, "G": 0.25, "C": 0.25 } }
    },
    {
      "name": "Homopolymer AAAA k=2",
      "input": { "sequence": "AAAA", "k": 2 },
      "output": { "frequencies": { "AA": 1.0 } }
    }
  ]
}
