{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "find_open_reading_frames",
  "serverName": "Analysis",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "GenomicAnalyzer.FindOpenReadingFrames",
  "docRef": "Seqeron.Genomics.Analysis/GenomicAnalyzer.cs#L449",
  "description": "Open reading frames in all 6 frames (3 forward + 3 reverse-complement): each ATG to its first in-frame stop (TAA/TAG/TGA) with length >= minLength nucleotides.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequence": { "type": "string", "description": "DNA sequence", "minLength": 1 },
      "minLength": { "type": "integer", "description": "Minimum ORF length in nucleotides (default 100)", "minimum": 1, "default": 100 }
    },
    "required": ["sequence"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "sequence": { "type": "string" },
            "position": { "type": "integer" },
            "frame": { "type": "integer" },
            "isReverseComplement": { "type": "boolean" },
            "length": { "type": "integer" },
            "codonCount": { "type": "integer" }
          },
          "required": ["sequence", "position", "frame", "isReverseComplement", "length", "codonCount"]
        }
      }
    },
    "required": ["items"]
  },
  "errors": [
    { "code": 1001, "message": "Sequence cannot be null or empty" },
    { "code": 1001, "message": "Invalid DNA sequence" },
    { "code": 1002, "message": "Minimum ORF length must be at least 1" }
  ],
  "examples": [
    {
      "name": "Minimal forward ORF ATG-TAA",
      "input": { "sequence": "ATGTAA", "minLength": 6 },
      "output": { "items": [ { "sequence": "ATGTAA", "position": 0, "frame": 1, "isReverseComplement": false, "length": 6, "codonCount": 2 } ] }
    },
    {
      "name": "One extra codon ATG-AAA-TAG",
      "input": { "sequence": "ATGAAATAG", "minLength": 9 },
      "output": { "items": [ { "sequence": "ATGAAATAG", "position": 0, "frame": 1, "isReverseComplement": false, "length": 9, "codonCount": 3 } ] }
    }
  ]
}
