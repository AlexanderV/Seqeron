{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "find_microsatellites",
  "serverName": "Analysis",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "RepeatFinder.FindMicrosatellites",
  "docRef": "Seqeron.Genomics.Analysis/RepeatFinder.cs#L67",
  "description": "Short Tandem Repeats (STRs / microsatellites): units of length minUnitLength..maxUnitLength repeated >= minRepeats times consecutively, each classified by repeat type. Redundant (self-repeating) units are skipped.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequence": { "type": "string", "description": "DNA sequence", "minLength": 1 },
      "minUnitLength": { "type": "integer", "description": "Minimum unit length (default 1)", "minimum": 1, "default": 1 },
      "maxUnitLength": { "type": "integer", "description": "Maximum unit length (default 6)", "default": 6 },
      "minRepeats": { "type": "integer", "description": "Minimum repeats (default 3)", "minimum": 2, "default": 3 }
    },
    "required": ["sequence"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "position": { "type": "integer" },
            "repeatUnit": { "type": "string" },
            "repeatCount": { "type": "integer" },
            "totalLength": { "type": "integer" },
            "repeatType": { "type": "string" }
          },
          "required": ["position", "repeatUnit", "repeatCount", "totalLength", "repeatType"]
        }
      }
    },
    "required": ["items"]
  },
  "errors": [
    { "code": 1001, "message": "Sequence cannot be null or empty" },
    { "code": 1002, "message": "Invalid unit-length or minRepeats bounds" }
  ],
  "examples": [
    {
      "name": "Dinucleotide (CA)4",
      "input": { "sequence": "CACACACA", "minUnitLength": 2, "maxUnitLength": 6, "minRepeats": 3 },
      "output": { "items": [ { "position": 0, "repeatUnit": "CA", "repeatCount": 4, "totalLength": 8, "repeatType": "Dinucleotide" } ] }
    },
    {
      "name": "Trinucleotide (CAG)3",
      "input": { "sequence": "CAGCAGCAG", "minUnitLength": 3, "maxUnitLength": 6, "minRepeats": 3 },
      "output": { "items": [ { "position": 0, "repeatUnit": "CAG", "repeatCount": 3, "totalLength": 9, "repeatType": "Trinucleotide" } ] }
    }
  ]
}
