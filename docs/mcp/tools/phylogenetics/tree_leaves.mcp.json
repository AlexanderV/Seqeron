{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "tree_leaves",
  "serverName": "Phylogenetics",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "PhylogeneticAnalyzer.GetLeaves",
  "docRef": "Seqeron.Genomics.Phylogenetics/PhylogeneticAnalyzer.cs#L801",
  "description": "Enumerate the leaf (taxon) nodes of a tree with their branch lengths.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "newick": { "type": "string", "description": "Tree in Newick format.", "minLength": 1 }
    },
    "required": ["newick"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "leaves": {
        "type": "array",
        "description": "Leaf nodes in left-to-right pre-order.",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "Leaf (taxon) name." },
            "branchLength": { "type": "number", "description": "Branch length to the parent." }
          },
          "required": ["name", "branchLength"]
        }
      }
    },
    "required": ["leaves"]
  },
  "errors": [
    { "code": 2001, "message": "Newick string is empty" }
  ],
  "examples": [
    {
      "name": "Balanced 4-taxon tree",
      "input": { "newick": "((A,B),(C,D));" },
      "output": {
        "leaves": [
          { "name": "A", "branchLength": 0 },
          { "name": "B", "branchLength": 0 },
          { "name": "C", "branchLength": 0 },
          { "name": "D", "branchLength": 0 }
        ]
      }
    },
    {
      "name": "Leaves with branch lengths",
      "input": { "newick": "((A:0.1,B:0.2,C:0.3):0.0,(D:0.4,E:0.5):0.6);" },
      "output": {
        "leaves": [
          { "name": "A", "branchLength": 0.1 },
          { "name": "B", "branchLength": 0.2 },
          { "name": "C", "branchLength": 0.3 },
          { "name": "D", "branchLength": 0.4 },
          { "name": "E", "branchLength": 0.5 }
        ]
      }
    }
  ]
}
