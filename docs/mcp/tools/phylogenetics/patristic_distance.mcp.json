{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "patristic_distance",
  "serverName": "Phylogenetics",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "PhylogeneticAnalyzer.PatristicDistance",
  "docRef": "Seqeron.Genomics.Phylogenetics/PhylogeneticAnalyzer.cs#L1125",
  "description": "Sum of branch lengths along the unique path between two taxa in a rooted tree.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "newick": { "type": "string", "description": "Tree in Newick format.", "minLength": 1 },
      "taxon1": { "type": "string", "description": "First taxon name." },
      "taxon2": { "type": "string", "description": "Second taxon name." }
    },
    "required": ["newick", "taxon1", "taxon2"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "distance": { "type": "number", "description": "Patristic distance; NaN when either taxon is missing; 0 for identical taxa." }
    },
    "required": ["distance"]
  },
  "errors": [
    { "code": 2001, "message": "Newick string is empty" }
  ],
  "examples": [
    {
      "name": "Sibling distance",
      "input": { "newick": "(A:1,B:2);", "taxon1": "A", "taxon2": "B" },
      "output": { "distance": 3 }
    },
    {
      "name": "Across a polytomy",
      "input": { "newick": "((A:0.1,B:0.2,C:0.3):0.0,(D:0.4,E:0.5):0.6);", "taxon1": "A", "taxon2": "C" },
      "output": { "distance": 0.4 }
    }
  ]
}
