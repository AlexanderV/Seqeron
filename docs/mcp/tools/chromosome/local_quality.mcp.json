{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "local_quality",
  "serverName": "Chromosome",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "GenomeAssemblyAnalyzer.CalculateLocalQuality",
  "docRef": "Seqeron.Genomics.Chromosome/GenomeAssemblyAnalyzer.cs#L1029",
  "description": "Compute per-window local quality metrics (GC content, N count, linguistic complexity).",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequences": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "sequence": { "type": "string" } }, "required": ["id", "sequence"] } },
      "windowSize": { "type": "integer", "default": 1000, "exclusiveMinimum": 0 }
    },
    "required": ["sequences"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": { "type": "array", "items": { "type": "object", "properties": { "sequenceId": { "type": "string" }, "position": { "type": "integer" }, "windowSize": { "type": "integer" }, "gcContent": { "type": "number" }, "nCount": { "type": "integer" }, "complexity": { "type": "number" } }, "required": ["sequenceId", "position", "windowSize", "gcContent", "nCount", "complexity"] } }
    },
    "required": ["items"]
  },
  "errors": [
    { "code": 1001, "message": "Sequences cannot be null" },
    { "code": 1002, "message": "Window size must be positive" }
  ],
  "examples": [
    { "name": "Single GC window", "input": { "sequences": [ { "id": "s", "sequence": "GCGCGCGCGC" } ], "windowSize": 1000 }, "output": { "items": [ { "sequenceId": "s", "position": 0, "windowSize": 10, "gcContent": 1.0, "nCount": 0 } ] } }
  ]
}
