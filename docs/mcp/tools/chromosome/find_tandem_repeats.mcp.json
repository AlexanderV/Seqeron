{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "find_tandem_repeats",
  "serverName": "Chromosome",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "GenomeAssemblyAnalyzer.FindTandemRepeats",
  "docRef": "Seqeron.Genomics.Chromosome/GenomeAssemblyAnalyzer.cs#L753",
  "description": "Identify tandem repeats; returns repeat unit, copy number and purity per occurrence.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequences": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "sequence": { "type": "string" } }, "required": ["id", "sequence"] } },
      "minUnitLength": { "type": "integer", "default": 2, "exclusiveMinimum": 0 },
      "maxUnitLength": { "type": "integer", "default": 50, "description": "Must be >= minUnitLength." },
      "minCopies": { "type": "integer", "default": 3, "exclusiveMinimum": 0 }
    },
    "required": ["sequences"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": { "type": "array", "items": { "type": "object", "properties": { "sequenceId": { "type": "string" }, "start": { "type": "integer" }, "end": { "type": "integer" }, "unit": { "type": "string" }, "copies": { "type": "integer" }, "purity": { "type": "number" } }, "required": ["sequenceId", "start", "end", "unit", "copies", "purity"] } }
    },
    "required": ["items"]
  },
  "errors": [
    { "code": 1001, "message": "Sequences cannot be null" },
    { "code": 1002, "message": "Minimum unit length must be positive" },
    { "code": 1003, "message": "Maximum unit length must be >= minimum unit length" },
    { "code": 1004, "message": "Minimum copies must be positive" }
  ],
  "examples": [
    { "name": "CAG triplet array", "input": { "sequences": [ { "id": "s", "sequence": "CAGCAG…(×30)" } ], "minUnitLength": 2, "maxUnitLength": 50, "minCopies": 3 }, "output": { "items": [ { "sequenceId": "s", "start": 0, "end": 89, "unit": "CAG", "copies": 30, "purity": 1.0 } ] } }
  ]
}
