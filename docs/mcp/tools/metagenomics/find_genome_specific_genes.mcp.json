{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "find_genome_specific_genes",
  "serverName": "Metagenomics",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "PanGenomeAnalyzer.FindGenomeSpecificGenes",
  "docRef": "Seqeron.Genomics.Metagenomics/PanGenomeAnalyzer.cs#L870",
  "description": "For each genome, list the cluster ids that occur only in that genome (singleton accessory clusters).",
  "inputSchema": {
    "type": "object",
    "properties": {
      "genomes": {
        "type": "array",
        "description": "Genomes (id + ordered list of genes).",
        "items": {
          "type": "object",
          "properties": {
            "genomeId": { "type": "string" },
            "genes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": { "geneId": { "type": "string" }, "sequence": { "type": "string" } },
                "required": ["geneId", "sequence"]
              }
            }
          },
          "required": ["genomeId", "genes"]
        }
      },
      "clusters": {
        "type": "array",
        "description": "Gene clusters covering the supplied genomes.",
        "items": {
          "type": "object",
          "properties": {
            "clusterId": { "type": "string" },
            "geneIds": { "type": "array", "items": { "type": "string" } },
            "genomeIds": { "type": "array", "items": { "type": "string" } },
            "genomeCount": { "type": "integer" },
            "averageIdentity": { "type": "number" },
            "consensusSequence": { "type": "string" }
          },
          "required": ["clusterId", "geneIds", "genomeIds", "genomeCount", "averageIdentity", "consensusSequence"]
        }
      }
    },
    "required": ["genomes", "clusters"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "genomeId": { "type": "string" },
            "uniqueGeneIds": { "type": "array", "items": { "type": "string" }, "description": "Singleton cluster ids owned only by this genome." }
          },
          "required": ["genomeId", "uniqueGeneIds"]
        }
      }
    },
    "required": ["items"]
  },
  "errors": [],
  "examples": [
    {
      "name": "Two genomes, each with one singleton cluster",
      "input": {
        "genomes": [
          { "genomeId": "g1", "genes": [ { "geneId": "unique1", "sequence": "AAAA" } ] },
          { "genomeId": "g2", "genes": [ { "geneId": "unique2", "sequence": "TTTT" } ] }
        ],
        "clusters": [
          { "clusterId": "c1", "geneIds": ["unique1"], "genomeIds": ["g1"], "genomeCount": 1, "averageIdentity": 1.0, "consensusSequence": "AAAA" },
          { "clusterId": "c2", "geneIds": ["unique2"], "genomeIds": ["g2"], "genomeCount": 1, "averageIdentity": 1.0, "consensusSequence": "TTTT" }
        ]
      },
      "output": { "items": [ { "genomeId": "g1", "uniqueGeneIds": ["c1"] }, { "genomeId": "g2", "uniqueGeneIds": ["c2"] } ] }
    },
    {
      "name": "No clusters",
      "input": { "genomes": [ { "genomeId": "g1", "genes": [] } ], "clusters": [] },
      "output": { "items": [] }
    }
  ]
}
