{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "variants_to_vcf",
  "serverName": "Annotation",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "VariantCaller.ToVcfLines",
  "docRef": "Seqeron.Genomics.Annotation/VariantCaller.cs#L350",
  "description": "Format variants as VCF v4.2 lines (header + records).",
  "inputSchema": {
    "type": "object",
    "properties": {
      "variants": {
        "type": "array",
        "description": "Variants to serialize",
        "items": {
          "type": "object",
          "properties": {
            "position": { "type": "integer", "description": "0-based reference position (serialized as 1-based POS)" },
            "referenceAllele": { "type": "string" },
            "alternateAllele": { "type": "string" },
            "type": { "type": "string" },
            "queryPosition": { "type": "integer" }
          },
          "required": ["position", "referenceAllele", "alternateAllele", "type"]
        }
      },
      "chromosome": { "type": "string", "description": "CHROM value for column 1", "default": "chr1" },
      "sampleName": { "type": "string", "description": "Sample column name in the VCF header", "default": "SAMPLE" }
    },
    "required": ["variants"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "lines": { "type": "array", "items": { "type": "string" }, "description": "VCF lines: 3 header lines followed by one record per variant" }
    },
    "required": ["lines"]
  },
  "errors": [
    { "code": 1001, "message": "Variants cannot be null" }
  ],
  "examples": [
    {
      "name": "Single SNP",
      "input": { "variants": [ { "position": 2, "referenceAllele": "G", "alternateAllele": "T", "type": "SNP", "queryPosition": 2 } ], "chromosome": "chr1", "sampleName": "SAMPLE" },
      "output": { "lines": [ "##fileformat=VCFv4.2", "##source=Seqeron.Genomics", "#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO\tFORMAT\tSAMPLE", "chr1\t3\t.\tG\tT\t.\tPASS\t.\tGT\t0/1" ] }
    },
    {
      "name": "Insertion (gap REF becomes '.')",
      "input": { "variants": [ { "position": 3, "referenceAllele": "-", "alternateAllele": "T", "type": "Insertion", "queryPosition": 3 } ], "chromosome": "chrX", "sampleName": "S1" },
      "output": { "lines": [ "##fileformat=VCFv4.2", "##source=Seqeron.Genomics", "#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO\tFORMAT\tS1", "chrX\t4\t.\t.\tT\t.\tPASS\t.\tGT\t0/1" ] }
    }
  ]
}
