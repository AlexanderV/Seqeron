{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "annotate_variants",
  "serverName": "Annotation",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "VariantCaller.AnnotateVariants",
  "docRef": "Seqeron.Genomics.Annotation/VariantCaller.cs#L318",
  "description": "Call every variant between a reference and a query DNA sequence and annotate each with a protein-level effect (when the reference is a coding sequence) and a Ti/Tv mutation-type classification.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "reference": { "type": "string", "description": "Reference DNA sequence", "minLength": 1 },
      "query": { "type": "string", "description": "Query DNA sequence", "minLength": 1 },
      "isCodingSequence": {
        "type": "boolean",
        "description": "When true, interpret the reference as a coding sequence and predict per-variant protein effects",
        "default": false
      }
    },
    "required": ["reference", "query"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "annotated": {
        "type": "array",
        "description": "One annotated variant per called difference",
        "items": {
          "type": "object",
          "properties": {
            "variant": {
              "type": "object",
              "properties": {
                "position": { "type": "integer", "description": "0-based position in the reference" },
                "referenceAllele": { "type": "string" },
                "alternateAllele": { "type": "string" },
                "type": { "type": "string", "description": "SNP / Insertion / Deletion / MNP / Complex" },
                "queryPosition": { "type": "integer" }
              },
              "required": ["position", "referenceAllele", "alternateAllele", "type", "queryPosition"]
            },
            "effect": { "type": "string", "description": "Synonymous / Missense / Nonsense / StopLoss / Frameshift / Unknown" },
            "mutationType": { "type": "string", "description": "Transition / Transversion / Other" }
          },
          "required": ["variant", "effect", "mutationType"]
        }
      }
    },
    "required": ["annotated"]
  },
  "errors": [
    { "code": 1001, "message": "Reference cannot be null or empty" },
    { "code": 1001, "message": "Query cannot be null or empty" }
  ],
  "examples": [
    {
      "name": "Coding missense SNP (ATG->ATT, Met->Ile)",
      "input": { "reference": "ATGCAT", "query": "ATTCAT", "isCodingSequence": true },
      "output": {
        "annotated": [
          { "variant": { "position": 2, "referenceAllele": "G", "alternateAllele": "T", "type": "SNP", "queryPosition": 2 }, "effect": "Missense", "mutationType": "Transversion" }
        ]
      }
    },
    {
      "name": "Same SNP treated as non-coding (effect Unknown)",
      "input": { "reference": "ATGCAT", "query": "ATTCAT", "isCodingSequence": false },
      "output": {
        "annotated": [
          { "variant": { "position": 2, "referenceAllele": "G", "alternateAllele": "T", "type": "SNP", "queryPosition": 2 }, "effect": "Unknown", "mutationType": "Transversion" }
        ]
      }
    }
  ]
}
