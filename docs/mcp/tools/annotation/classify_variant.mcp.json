{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "classify_variant",
  "serverName": "Annotation",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "VariantAnnotator.ClassifyVariant",
  "docRef": "Seqeron.Genomics.Annotation/VariantAnnotator.cs#L196",
  "description": "Classify a (ref, alt) allele pair as SNV / Insertion / Deletion / MNV / Indel / Complex.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "reference": { "type": "string", "description": "Reference allele", "minLength": 1 },
      "alternate": { "type": "string", "description": "Alternate allele", "minLength": 1 }
    },
    "required": ["reference", "alternate"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "variantType": { "type": "string", "description": "SNV / Insertion / Deletion / MNV / Indel / Complex" }
    },
    "required": ["variantType"]
  },
  "errors": [
    { "code": 1001, "message": "Reference allele cannot be null or empty" },
    { "code": 1001, "message": "Alternate allele cannot be null or empty" }
  ],
  "examples": [
    {
      "name": "SNV",
      "input": { "reference": "A", "alternate": "G" },
      "output": { "variantType": "SNV" }
    },
    {
      "name": "Insertion",
      "input": { "reference": "A", "alternate": "ACGT" },
      "output": { "variantType": "Insertion" }
    }
  ]
}
