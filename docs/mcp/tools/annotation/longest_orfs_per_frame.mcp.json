{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "longest_orfs_per_frame",
  "serverName": "Annotation",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "GenomeAnnotator.FindLongestOrfsPerFrame",
  "docRef": "Seqeron.Genomics.Annotation/GenomeAnnotator.cs#L236",
  "description": "Return the longest ORF in each of the (up to) six reading frames.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "dnaSequence": { "type": "string", "description": "DNA sequence to search", "minLength": 1 },
      "searchBothStrands": { "type": "boolean", "description": "Whether to also search the reverse complement (frames -1..-3)", "default": true }
    },
    "required": ["dnaSequence"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "frames": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "frame": { "type": "integer", "description": "Reading frame: 1..3 forward, -1..-3 reverse" },
            "orf": {
              "type": "object",
              "description": "Longest ORF in this frame; an all-zero/empty sentinel ORF when the frame has no start/stop ORF",
              "properties": {
                "start": { "type": "integer" },
                "end": { "type": "integer" },
                "frame": { "type": "integer" },
                "isReverseComplement": { "type": "boolean" },
                "sequence": { "type": "string" },
                "proteinSequence": { "type": "string" }
              }
            }
          },
          "required": ["frame", "orf"]
        }
      }
    },
    "required": ["frames"]
  },
  "errors": [
    { "code": 1001, "message": "Sequence cannot be null or empty" }
  ],
  "examples": [
    {
      "name": "Single forward ORF (forward strand only)",
      "input": { "dnaSequence": "ATGAAAAAAAAATAA", "searchBothStrands": false },
      "output": { "frames": [ { "frame": 1, "orf": { "start": 0, "end": 15, "frame": 1, "isReverseComplement": false, "sequence": "ATGAAAAAAAAATAA", "proteinSequence": "MKKK*" } }, { "frame": 2, "orf": { "start": 0, "end": 0, "frame": 0, "isReverseComplement": false, "sequence": null, "proteinSequence": null } }, { "frame": 3, "orf": { "start": 0, "end": 0, "frame": 0, "isReverseComplement": false, "sequence": null, "proteinSequence": null } } ] }
    },
    {
      "name": "Both strands return six frame slots",
      "input": { "dnaSequence": "ATGAAAAAAAAATAA", "searchBothStrands": true },
      "output": { "frames": [ { "frame": 1 }, { "frame": 2 }, { "frame": 3 }, { "frame": -1 }, { "frame": -2 }, { "frame": -3 } ] }
    }
  ]
}
