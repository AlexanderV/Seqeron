{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "find_orfs",
  "serverName": "Annotation",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "GenomeAnnotator.FindOrfs",
  "docRef": "Seqeron.Genomics.Annotation/GenomeAnnotator.cs#L104",
  "description": "Find all open reading frames (ORFs) in a DNA sequence across forward and reverse strands.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "dnaSequence": { "type": "string", "description": "DNA sequence to search", "minLength": 1 },
      "minLength": { "type": "integer", "description": "Minimum ORF length in amino acids", "default": 100 },
      "searchBothStrands": { "type": "boolean", "description": "Whether to also search the reverse complement", "default": true },
      "requireStartCodon": { "type": "boolean", "description": "Whether to require a start codon (ATG/GTG/TTG)", "default": true }
    },
    "required": ["dnaSequence"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "orfs": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "start": { "type": "integer", "description": "0-based start position on the forward strand" },
            "end": { "type": "integer", "description": "Exclusive end position on the forward strand (includes the stop codon)" },
            "frame": { "type": "integer", "description": "Reading frame 1..3" },
            "isReverseComplement": { "type": "boolean", "description": "True if the ORF was found on the reverse strand" },
            "sequence": { "type": "string", "description": "The ORF nucleotide sequence (start codon through stop codon)" },
            "proteinSequence": { "type": "string", "description": "Translated protein, ending with '*' for the stop codon" }
          },
          "required": ["start", "end", "frame", "isReverseComplement", "sequence", "proteinSequence"]
        }
      }
    },
    "required": ["orfs"]
  },
  "errors": [
    { "code": 1001, "message": "Sequence cannot be null or empty" }
  ],
  "examples": [
    {
      "name": "Simple ATG..TAA ORF",
      "input": { "dnaSequence": "ATGAAAAAAAAATAA", "minLength": 1, "searchBothStrands": false },
      "output": { "orfs": [ { "start": 0, "end": 15, "frame": 1, "isReverseComplement": false, "sequence": "ATGAAAAAAAAATAA", "proteinSequence": "MKKK*" } ] }
    },
    {
      "name": "No ORF below minimum length",
      "input": { "dnaSequence": "ATGAAAAAAAAATAA", "minLength": 10, "searchBothStrands": false },
      "output": { "orfs": [] }
    }
  ]
}
