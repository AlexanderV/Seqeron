{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "toolName": "global_align",
  "serverName": "Alignment",
  "version": "1.0.0",
  "stability": "stable",
  "methodId": "SequenceAligner.GlobalAlign",
  "docRef": "Seqeron.Genomics.Alignment/SequenceAligner.cs#L72",
  "description": "Global pairwise alignment (Needleman-Wunsch): align the full length of both sequences end-to-end under a configurable match/mismatch/gap scoring.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "sequence1": {
        "type": "string",
        "description": "First sequence (DNA, uppercased internally).",
        "minLength": 1
      },
      "sequence2": {
        "type": "string",
        "description": "Second sequence.",
        "minLength": 1
      },
      "match": {
        "type": "integer",
        "description": "Score for matching base.",
        "default": 1
      },
      "mismatch": {
        "type": "integer",
        "description": "Score for mismatching base.",
        "default": -1
      },
      "gapOpen": {
        "type": "integer",
        "description": "Gap-open penalty.",
        "default": -2
      },
      "gapExtend": {
        "type": "integer",
        "description": "Gap-extend penalty (linear gap per position).",
        "default": -1
      }
    },
    "required": [
      "sequence1",
      "sequence2"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "alignedSequence1": {
        "type": "string",
        "description": "Aligned sequence1 (with '-' gaps)."
      },
      "alignedSequence2": {
        "type": "string",
        "description": "Aligned sequence2 (with '-' gaps)."
      },
      "score": {
        "type": "integer",
        "description": "Optimal global alignment score."
      },
      "alignmentType": {
        "type": "string",
        "description": "Alignment type (\"Global\")."
      },
      "startPosition1": {
        "type": "integer",
        "description": "0-based start in sequence1."
      },
      "startPosition2": {
        "type": "integer",
        "description": "0-based start in sequence2."
      },
      "endPosition1": {
        "type": "integer",
        "description": "0-based end in sequence1."
      },
      "endPosition2": {
        "type": "integer",
        "description": "0-based end in sequence2."
      }
    },
    "required": [
      "alignedSequence1",
      "alignedSequence2",
      "score",
      "alignmentType",
      "startPosition1",
      "startPosition2",
      "endPosition1",
      "endPosition2"
    ]
  },
  "errors": [
    {
      "code": 1001,
      "message": "Sequence cannot be null or empty"
    }
  ],
  "examples": [
    {
      "name": "Identical",
      "input": {
        "sequence1": "GATTACA",
        "sequence2": "GATTACA"
      },
      "output": {
        "alignedSequence1": "GATTACA",
        "alignedSequence2": "GATTACA",
        "score": 7,
        "alignmentType": "Global",
        "startPosition1": 0,
        "startPosition2": 0,
        "endPosition1": 6,
        "endPosition2": 6
      }
    },
    {
      "name": "One deletion",
      "input": {
        "sequence1": "GATTACA",
        "sequence2": "GATACA"
      },
      "output": {
        "alignedSequence1": "GATTACA",
        "alignedSequence2": "GA-TACA",
        "score": 5,
        "alignmentType": "Global",
        "startPosition1": 0,
        "startPosition2": 0,
        "endPosition1": 6,
        "endPosition2": 5
      }
    }
  ]
}
