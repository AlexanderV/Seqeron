#!/bin/sh
# LLM Wiki pre-commit guard.
#
# Sources of truth for the wiki (KEEP IN SYNC with wiki/SCHEMA.md
# "Source-of-truth rules"):
#   - everything under docs/
#   - the root-level markdown files enumerated in SOURCES_RE below
#
# When any source OR any wiki page is staged, run the deterministic staleness
# check (blocking) and a coverage report (soft) so drift surfaces at commit time.
#
# To add a new root source, edit THREE places so they stay identical:
#   1) the SOURCES_RE regexp here
#   2) a matching --extra flag in the coverage call below
#   3) wiki/SCHEMA.md

SKILL=.claude/skills/llm-wiki/scripts

# A single regexp is the whole source list. Root files are anchored with $ so a
# nested file like docs/README.md matches the docs/ arm, not the root arm.
SOURCES_RE='^(docs/|wiki/|README\.md$|ALGORITHMS_CHECKLIST_V2\.md$|ALGORITHMS_ROADMAP\.md$)'

staged=$(git diff --cached --name-only --diff-filter=ACMR)
echo "$staged" | grep -Eq "$SOURCES_RE" || exit 0

echo "[wiki] source or wiki change staged — checking staleness + coverage"

python "$SKILL/wiki_stale.py" wiki
if [ $? -ne 0 ]; then
  echo "[wiki] stale pages above: re-ingest the changed source(s), or run" >&2
  echo "       'git commit --no-verify' if this is intentional." >&2
  exit 1
fi

# Soft mode: report only (|| true). Once the initial ingest backlog is cleared,
# add --strict here to make an unreferenced source block the commit.
python "$SKILL/wiki_coverage.py" wiki \
  --extra README.md \
  --extra ALGORITHMS_CHECKLIST_V2.md \
  --extra ALGORITHMS_ROADMAP.md \
  || true

exit 0
