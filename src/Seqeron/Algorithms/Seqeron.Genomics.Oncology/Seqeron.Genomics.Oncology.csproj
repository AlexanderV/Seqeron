<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>Seqeron.Genomics.Oncology</RootNamespace>
    <AssemblyName>Seqeron.Genomics.Oncology</AssemblyName>
    
    <PackageId>Seqeron.Genomics.Oncology</PackageId>
    <Version>1.0.0</Version>
    <Authors>Seqeron</Authors>
    <Description>Oncology genomics: immune infiltration estimation, tumor expression analysis, immune cell deconvolution.</Description>
    <PackageTags>bioinformatics;genomics;oncology;immune;deconvolution;CIBERSORT;ESTIMATE</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Seqeron.Genomics.Infrastructure\Seqeron.Genomics.Infrastructure.csproj" />
    <ProjectReference Include="..\Seqeron.Genomics.Core\Seqeron.Genomics.Core.csproj" />
    <ProjectReference Include="..\Seqeron.Genomics.Analysis\Seqeron.Genomics.Analysis.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Seqeron.Genomics.Infrastructure" />
    <Using Include="Seqeron.Genomics.Core" />
    <Using Include="Seqeron.Genomics.Analysis" />
  </ItemGroup>

</Project>
