# Repository-root EditorConfig. Establishes one shared style baseline for the whole
# solution; the nested .editorconfig files (src/SuffixTree/Algorithms, the test tree)
# layer project-specific overrides on top.
#
# Note: these code-style rules are IDE/analyzer guidance only. EnforceCodeStyleInBuild
# is intentionally left off, so nothing here turns into a build warning/error under the
# solution-wide TreatWarningsAsErrors gate.
root = true

# ── All files ────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ── Project / MSBuild / config files ─────────────────────────────────────────
[*.{csproj,props,targets,config,nuspec}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # trailing double-space is a hard line break in Markdown

# ── C# ───────────────────────────────────────────────────────────────────────
[*.cs]
indent_size = 4

# Namespaces & usings
csharp_style_namespace_declarations = file_scoped:suggestion
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# `var` preferences
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-level preferences
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_prefer_simple_using_statement = true:suggestion

# Null-checking
csharp_style_throw_expression = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion

# `this.` qualification — off, this codebase does not qualify
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Modifiers
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:suggestion
dotnet_style_readonly_field = true:suggestion

# Naming: interfaces start with I, types & members PascalCase
dotnet_naming_rule.interfaces_start_with_i.severity = suggestion
dotnet_naming_rule.interfaces_start_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_start_with_i.style = begins_with_i
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_symbols.interface_symbols.applicable_accessibilities = *
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# ── Analyzer policy ──────────────────────────────────────────────────────────
# Curated "clean out the crap" ruleset. These are elevated to warning (=> error
# under the solution-wide TreatWarningsAsErrors) because they flag genuine dead/
# redundant/legacy code and are almost all auto-fixable by `dotnet format`.
# The opinionated or codebase-inappropriate rules are silenced below so the gate
# stays signal, not noise.

# Dead / unused code
# IDE0005 (unused usings) is kept at suggestion: enforcing it at build requires
# GenerateDocumentationFile=true (a Roslyn limitation) which would in turn surface the
# CS1591 missing-doc-comment flood. `dotnet format` already stripped the unused usings.
dotnet_diagnostic.IDE0005.severity = suggestion   # unnecessary using directives
dotnet_diagnostic.CA1823.severity = warning    # unused private fields
dotnet_diagnostic.IDE0051.severity = warning   # unused private members
dotnet_diagnostic.IDE0052.severity = warning   # unread private members

# Redundant / legacy constructs (auto-fixable modernizations)
dotnet_diagnostic.CA1802.severity = warning    # use const where possible
dotnet_diagnostic.CA1805.severity = warning    # do not initialize to default unnecessarily
dotnet_diagnostic.CA1825.severity = warning    # use Array.Empty<T>()
dotnet_diagnostic.CA1852.severity = suggestion # seal internal types — mostly test-helper visitors; low value/high churn
dotnet_diagnostic.CA1510.severity = warning    # use ArgumentNullException.ThrowIfNull
dotnet_diagnostic.CA1511.severity = warning    # use ArgumentException.ThrowIfNullOrEmpty
dotnet_diagnostic.CA1512.severity = warning    # use ArgumentOutOfRangeException.ThrowIf*
dotnet_diagnostic.CA1513.severity = warning    # use ObjectDisposedException.ThrowIf
dotnet_diagnostic.CA2263.severity = warning    # prefer the generic overload

# Redundant allocations / slow idioms (auto-fixable, also cleanup)
dotnet_diagnostic.CA1826.severity = warning    # use property instead of Enumerable method
dotnet_diagnostic.CA1827.severity = warning    # Count()/LongCount() -> Any()
dotnet_diagnostic.CA1829.severity = warning    # use Length/Count property
dotnet_diagnostic.CA1845.severity = warning    # span-based string.Concat
dotnet_diagnostic.CA1846.severity = warning    # AsSpan over Substring
dotnet_diagnostic.CA1847.severity = warning    # use char literal for single-char search
dotnet_diagnostic.CA1860.severity = warning    # prefer Length/Count over Any()
dotnet_diagnostic.CA1866.severity = warning    # use char overloads
dotnet_diagnostic.CA1868.severity = warning    # unnecessary Contains before Add/Remove
dotnet_diagnostic.CA1870.severity = warning    # use cached SearchValues
dotnet_diagnostic.CA2249.severity = warning    # use string.Contains over IndexOf
dotnet_diagnostic.CA1854.severity = warning    # prefer TryGetValue over ContainsKey+indexer

# Correctness smells worth surfacing (kept for a second, manual pass)
dotnet_diagnostic.CA2241.severity = suggestion # format-string argument count
dotnet_diagnostic.CA1806.severity = suggestion # do not ignore method results
dotnet_diagnostic.CA1508.severity = suggestion # avoid dead conditional code
dotnet_diagnostic.CA1851.severity = suggestion # possible multiple enumeration

# ── Silenced: opinionated or inappropriate for this library ─────────────────
dotnet_diagnostic.CA1707.severity = none       # underscores — standard in test/unit-id names
dotnet_diagnostic.CA1515.severity = none       # "make public internal" — this is a library
dotnet_diagnostic.CA5394.severity = none       # Random — used for test data / sampling, not crypto
dotnet_diagnostic.CA1861.severity = none       # constant arrays as args — micro-perf, huge noise
dotnet_diagnostic.CA1062.severity = none       # null-validate public args — pervasive opinion
dotnet_diagnostic.CA1034.severity = none       # nested types — used deliberately as result DTOs
dotnet_diagnostic.CA1819.severity = none       # arrays as properties — fine for numeric buffers
dotnet_diagnostic.CA1814.severity = none       # jagged vs multidimensional
dotnet_diagnostic.CA1002.severity = none       # List<T> in APIs
dotnet_diagnostic.CA2007.severity = none       # ConfigureAwait — not a UI/library-sync concern here
dotnet_diagnostic.CA1305.severity = none       # IFormatProvider — ASCII bioinformatics, culture-free
dotnet_diagnostic.CA1307.severity = none       # StringComparison — ditto
dotnet_diagnostic.CA1310.severity = none       # StringComparison for correctness — ditto
dotnet_diagnostic.CA1311.severity = none       # ToUpper culture — ditto
dotnet_diagnostic.CA1304.severity = none       # CultureInfo — ditto
dotnet_diagnostic.CA1308.severity = none       # ToLowerInvariant preference
dotnet_diagnostic.CA1859.severity = none       # concrete types for perf — not "crap", risky on APIs
dotnet_diagnostic.CA2000.severity = none       # dispose-before-scope — many false positives with pooling
dotnet_diagnostic.CA1815.severity = none       # equals/hashcode on value types

# ── Silenced: SonarAnalyzer rules that fight deliberate design of this library ────────────────
dotnet_diagnostic.S2245.severity = none        # Random — test data / sampling, not crypto (cf. CA5394)
dotnet_diagnostic.S1133.severity = none        # "remove deprecated code someday" — informational, not actionable
dotnet_diagnostic.S6640.severity = none        # unsafe blocks — deliberate for memory-mapped persistence / perf
dotnet_diagnostic.S1215.severity = none        # GC.Collect — deliberate in perf / memory-measurement paths
dotnet_diagnostic.S101.severity = none         # type naming — interop (WIN32_*), acronyms (SNP), benchmark ids (cf. CA1707)
# S1172: unused parameters here are predominantly deliberate — HMM/RNA dynamic-programming function
# families that pass a consistent (matrix / length / index) signature, symmetric helper pairs, pipeline
# placeholder methods documented as "simplified" (reserving transcript/referenceSequence for the full
# impl), and faithful algorithm ports. Removing them breaks the intended signatures and cascades into
# callers; a minority are genuinely dead and can be pruned in a focused pass. Opinion-heavy for this library.
dotnet_diagnostic.S1172.severity = none
# S4136: methods are organised by functional grouping, not overload-name adjacency — FastaParser keeps
# per-mode trios (Parse/ParseFile/ParseFileAsync), and the SuffixTree partials keep each public API
# method next to its private helpers. Forcing overload adjacency would fragment those deliberate groups.
dotnet_diagnostic.S4136.severity = none
# S2368: public jagged/multidimensional arrays — Sonar analog of CA1814/CA1819, already silenced above
# (numeric buffers are exposed as arrays by design in this library).
dotnet_diagnostic.S2368.severity = none
# S3218: members of public result records/DTOs (e.g. ContextPlusPlusScore's documented contribution
# properties) coincide with outer-class members. C# access is unambiguous via the instance; renaming
# would break the public API and degrade the descriptive scientific names for a harmless coincidence.
dotnet_diagnostic.S3218.severity = none
# S1199: bare-brace scoping blocks deliberately delimit phases of dense dynamic-programming algorithms
# (RNA folding / thermodynamics), keeping the DP state local. Extracting each into a method would
# thread that state through many small methods and fragment the algorithm — a readability net-negative.
dotnet_diagnostic.S1199.severity = none

# ── Test code: relax the aggressive cleanup rules ────────────────────────────
# Production code is fully cleaned and gated above. In test code these rules are
# advisory only: removing an "unused" private field/helper can silently delete
# intended-but-unwired fixtures/coverage (e.g. GC-rich / AT-rich templates), and
# the perf micro-optimizations add no value to test scaffolding.
[tests/**/*.cs]
dotnet_diagnostic.IDE0051.severity = suggestion   # unused private members
dotnet_diagnostic.IDE0052.severity = suggestion   # unread private members
dotnet_diagnostic.CA1823.severity = suggestion    # unused private fields
dotnet_diagnostic.CA1868.severity = suggestion    # Contains-before-Add
dotnet_diagnostic.CA1870.severity = suggestion    # cached SearchValues
# Sonar equivalents of the unused-member rules above: same rationale — an "unused" private
# field/method/property in a fixture is often intended-but-unwired coverage, not dead code.
dotnet_diagnostic.S4487.severity = suggestion     # unread private field (e.g. GC/AT-rich templates)
dotnet_diagnostic.S1144.severity = suggestion     # unused private member
# S3973: stacked `for`/`foreach` grid-iteration loops are an intentional, readable idiom in these
# combinatorial tests; brace-style is not enforced in test scaffolding.
dotnet_diagnostic.S3973.severity = suggestion
# S927: parameter-name conformance to an interface matters for named-argument callers of a public API,
# not for pass-through test doubles; all sites are test mocks that just forward to an inner impl.
dotnet_diagnostic.S927.severity = suggestion
# S1481: an "unused" local in a test is usually a `var r = MethodUnderTest(...)` exercise-call whose
# result isn't asserted (coverage / no-throw). Same rationale as the unused-member rules above —
# removing it silently deletes intended coverage. Enforced in production; advisory in tests.
dotnet_diagnostic.S1481.severity = suggestion
# S2971 (drop useless ToList) / S6608 (index instead of .Last()): micro-perf/style. Removing a
# ToList in a test can change deferred-execution semantics; both add no value to test scaffolding.
# Enforced in production; advisory in tests.
dotnet_diagnostic.S2971.severity = suggestion
dotnet_diagnostic.S6608.severity = suggestion
# S6966: all sites are sync test methods calling `...Async(...).GetAwaiter().GetResult()` — the correct
# pattern when the test itself is not async; "await instead" would force the test to become async.
dotnet_diagnostic.S6966.severity = suggestion
# S108: empty blocks in test scaffolding are typically intentional (empty catch in a throwing test
# double, empty exercise loops). Enforced in production; advisory in tests.
dotnet_diagnostic.S108.severity = suggestion
# S2114: determinism property tests intentionally call f(x).SequenceEqual(f(x)) to prove a function
# is pure/reproducible — the two calls are meant to be re-evaluated, not folded to "always true".
dotnet_diagnostic.S2114.severity = none
# S2234: symmetry / permutation-invariance tests deliberately pass arguments in swapped order
# (e.g. HammingDistance(b,a), all permutations of an HRD triple) to assert the result is invariant.
dotnet_diagnostic.S2234.severity = none
